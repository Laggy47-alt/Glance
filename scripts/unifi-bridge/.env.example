# Self-hosted Glance Supabase URL (no trailing slash)
GLANCE_URL=https://supabase.example.com

# Supabase anon key from the same project
GLANCE_ANON_KEY=eyJhbGciOi...

# Path to instances.json (default ./instances.json) — or use INSTANCES_JSON for an inline array
INSTANCES_FILE=./instances.json

# debug | info  (default info)
LOG_LEVEL=info

# Person-only smart-detect filter (default true)
PERSON_ONLY=true

# ── Camera health polling ──
# How often to push camera online/offline status to Glance.
STATUS_INTERVAL_SEC=30

# ── Live view (MJPEG snapshot) HTTP server ──
# Port to bind on this machine (0 disables). Publish behind your reverse proxy /
# firewall and set bridge_public_url on each NVR in the Glance UI.
HTTP_PORT=8787
# Shared secret required on ?token=  (also stored per-NVR as live_token).
BRIDGE_LIVE_TOKEN=change-me-long-random
# Snapshot frames per second sent to the browser (1–10).
LIVE_FPS=2
