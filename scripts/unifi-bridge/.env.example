# Self-hosted Glance Supabase URL (no trailing slash)
GLANCE_URL=https://supabase.example.com

# Supabase anon key from the same project
GLANCE_ANON_KEY=eyJhbGciOi...

# Path to instances.json (default ./instances.json) — or use INSTANCES_JSON for an inline array
INSTANCES_FILE=./instances.json

# debug | info  (default info)
LOG_LEVEL=info
