[Unit]
Description=Mudslide WhatsApp incoming-message listener
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mudslide
Group=mudslide
WorkingDirectory=/opt/mudslide-listener
EnvironmentFile=/opt/mudslide-listener/.env
ExecStart=/usr/bin/node /opt/mudslide-listener/listener.mjs
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
