# Copy this file to `.env` before running `npm install` / `npm run build`.
#
# These values point the frontend at your Supabase (or self-hosted Supabase)
# project. They are PUBLIC values — safe to ship in a built bundle — but they
# MUST match the backend you intend to use.

# REST + Auth API root, e.g. https://yourproject.supabase.co
VITE_SUPABASE_URL=

# anon / publishable key (NOT the service role key)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Project ref (the subdomain part of the URL above)
VITE_SUPABASE_PROJECT_ID=
